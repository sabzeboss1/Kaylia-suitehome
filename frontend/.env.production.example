# ============================================
# KAYLIA SUITE HOME - FRONTEND PRODUCTION
# ============================================
# 
# IMPORTANT: Copy this file to .env.production and fill in all values
# These values will be embedded in the built JavaScript
#

# ============================================
# API CONFIGURATION
# ============================================
VITE_API_BASE_URL=https://kayliasuitehome.com/api
VITE_API_URL=https://kayliasuitehome.com

# ============================================
# STRIPE (PRODUCTION PUBLIC KEY)
# ============================================
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_live_CHANGE_ME

# ============================================
# PAYPAL (PRODUCTION CLIENT ID)
# ============================================
# Get from: https://developer.paypal.com/dashboard/
VITE_PAYPAL_CLIENT_ID=CHANGE_ME

# ============================================
# RECAPTCHA (SITE KEY)
# ============================================
# Get from: https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=CHANGE_ME

# ============================================
# SENTRY (ERROR TRACKING)
# ============================================
# Get from: https://sentry.io/settings/projects/
VITE_SENTRY_DSN=https://CHANGE_ME@sentry.io/PROJECT_ID

# ============================================
# APPLICATION INFO
# ============================================
VITE_APP_NAME="Kaylia Suite Home"
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production

# ============================================
# CONTACT INFO
# ============================================
VITE_WHATSAPP_NUMBER=+237658973853
VITE_CONTACT_EMAIL=contact@kayliasuitehome.com
VITE_CONTACT_PHONE=+237658973853

# ============================================
# SOCIAL MEDIA
# ============================================
VITE_INSTAGRAM_URL=https://instagram.com/kayliasuitehome
VITE_FACEBOOK_URL=https://facebook.com/kayliasuitehome
VITE_TWITTER_URL=https://twitter.com/kayliasuitehome

# ============================================
# ANALYTICS (OPTIONAL)
# ============================================
VITE_GOOGLE_ANALYTICS_ID=
VITE_FACEBOOK_PIXEL_ID=

# ============================================
# FEATURE FLAGS
# ============================================
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_PERFORMANCE_MONITORING=true
